# Remnawave Node Lite 环境配置
# 路径：/etc/remnanode/node.env
# 权限建议：chmod 600 /etc/remnanode/node.env

# Panel 下发的节点密钥（base64 JSON，含 caCertPem/jwtPublicKey/nodeCertPem/nodeKeyPem）
# 推荐写入独立文件（支持超长 Key），二选一：
SECRET_KEY_FILE=/etc/remnanode/secret.key
# SECRET_KEY=

# HTTPS 监听端口（Panel -> Node）
NODE_PORT=2222

# 本地 Xray gRPC API 端口（默认 61000，勿与 NODE_PORT 冲突）
XTLS_API_PORT=61000

# rw-core 二进制路径
XRAY_BIN=/usr/local/bin/rw-core

# Xray geo 资源目录
GEO_DIR=/usr/local/share/xray

# Xray 子进程日志目录
LOG_DIR=/var/log/remnanode

# 设为 true 可禁用 hash 比对，每次 start 都强制重启 core（调试用）
DISABLE_HASHED_SET_CHECK=false

# 以下留空则由进程启动时自动生成
INTERNAL_SOCKET_PATH=
INTERNAL_REST_TOKEN=

# 低内存 VPS（128/256MB）：install-node.sh --low-memory
# LOW_MEMORY=1
# BODY_LIMIT_MB=64

# CAP_NET_ADMIN 由 deploy/remnawave-node.service 的 AmbientCapabilities 授予，无需在此配置
